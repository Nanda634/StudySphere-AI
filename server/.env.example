PORT=5000

# Get this from your Neon project -> Connection Details -> pooled connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&channel_binding=require"

JWT_SECRET="change_this_to_a_long_random_secret"

# --- Email OTP verification (used at registration) ---
# Any standard SMTP provider works. For Gmail: enable 2FA on the account, then create an
# "App Password" (https://myaccount.google.com/apppasswords) and use that as SMTP_PASS —
# your normal Gmail password will NOT work here.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM="StudySphere AI <your_email@gmail.com>"
OTP_EXPIRY_MINUTES=10

# --- AI (Google Gemini — the only provider) ---
# Get a free key (no billing required) at https://aistudio.google.com/apikey
# Flash models have a genuinely free, rate-limited tier.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
